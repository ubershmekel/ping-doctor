{
  "manifest_version": 3,
  "name": "PingDoctor",
  "version": "1.0.1",
  "description": "Monitor your router and selected HTTP endpoints to spot outages and slowdowns.",
  "permissions": [
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background/worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/index.html",
    "default_icon": "icons/icon48.png"
  },
  "options_page": "options/index.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
